generator client {
  provider     = "prisma-client-js"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String         @id @default(uuid())
  username  String         @unique
  email     String         @unique
  password  String
  avatar    String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  watchlist Watchlist[]
  reviews   Review[]
  tokens    RefreshToken[]
}

model Watchlist {
  id      String   @id @default(uuid())
  userId  String
  movieId Int // ID que viene de TMDB
  addedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId]) // un usuario no puede agregar la misma película dos veces
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  movieId   Int
  rating    Float // 1.0 a 10.0
  content   String   @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // se actualiza de forma automatica cada vez que se edita el registro

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
